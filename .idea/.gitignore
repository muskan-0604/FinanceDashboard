# Default ignored files
/shelf/
/workspace.xml
# Build output
/target/
*.jar
*.war
*.class

# IntelliJ IDEA
/.idea/
/*.iml
/*.iws

# Eclipse
/.classpath
/.project
/.settings/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.bak

# Environment / sensitive files (optional, only if they contain secrets)
/application.properties
/application.yml

# Maven
/.mvn/
!/.mvn/wrapper/maven-wrapper.jar
